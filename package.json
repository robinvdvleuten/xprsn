{
	"name": "xprsn",
	"version": "0.4.0",
	"description": "Tiny, CSP-safe expression language for JavaScript. No eval, no new Function.",
	"repository": "robinvdvleuten/xprsn",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
	}
  	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "1.5 kB"
		},
		{
			"path": "dist/index.cjs",
			"limit": "1.5 kB"
		}
	],
	"scripts": {
		"bench": "node bench/index.js",
		"build": "tsdown",
		"prepublishOnly": "npm run build",
		"size": "size-limit",
		"test": "node --disallow-code-generation-from-strings node_modules/tape/bin/tape test/*.test.js && npm run typecheck",
		"typecheck": "tsc --noEmit --strict test/types.check.ts"
	},
	"keywords": [
		"expression",
		"expression-language",
		"csp",
		"parser",
		"evaluate"
	],
	"devDependencies": {
		"@size-limit/file": "^12.1.0",
		"size-limit": "^12.1.0",
		"tape": "^5.9.0",
		"tsdown": "^0.22.12",
		"typescript": "^7.0.2"
	}
}
